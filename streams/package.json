{
  "name": "@queenmq/streams",
  "version": "0.2.0",
  "type": "module",
  "description": "Fat-client streaming engine on top of Queen MQ. Operators run in your Node process; state, sink push, and source ack commit in one Postgres transaction.",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./operators": "./src/operators/index.js"
  },
  "files": [
    "index.js",
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/operators.test.js test/cycle.test.js test/configHash.test.js test/eventTime.test.js",
    "test:e2e": "node --test test/e2e.test.js"
  },
  "peerDependencies": {
    "queen-mq": ">=0.14.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Smartness",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartpricing/queen"
  },
  "keywords": [
    "queen",
    "queenmq",
    "streaming",
    "stream-processing",
    "postgres",
    "exactly-once",
    "windowed-aggregation"
  ]
}
